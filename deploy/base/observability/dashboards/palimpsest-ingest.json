{
  "uid": "palimpsest-ingest",
  "title": "PALIMPSEST — Ingest, Projector & Data",
  "tags": ["palimpsest", "ingest", "data"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Import (Flow A)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Import throughput (claims/s)",
      "description": "rate of palimpsest_import_claims_total. SLO reference: >= 5k claims/s sustained (§5.1).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(palimpsest_import_claims_total[1m]))", "legendFormat": "claims/s inserted" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Import outcomes: inserted / duplicates / superseded / rejected",
      "description": "Per-batch report counters (Flow A step 7). Rejected > 0 is operator-actionable.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(increase(palimpsest_import_claims_total[$__rate_interval]))", "legendFormat": "inserted" },
        { "refId": "B", "expr": "sum(increase(palimpsest_import_duplicates_total[$__rate_interval]))", "legendFormat": "duplicates" },
        { "refId": "C", "expr": "sum(increase(palimpsest_import_superseded_total[$__rate_interval]))", "legendFormat": "superseded" },
        { "refId": "D", "expr": "sum(increase(palimpsest_import_rejected_total[$__rate_interval]))", "legendFormat": "rejected" }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Projector / outbox lag (§3.4 SLO: < 60s p99 at steady state)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Outbox pending rows (0 == caught up)",
      "description": "palimpsest_outbox_pending_rows. The kind smoke asserts this is 0 at rest.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 1000 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "max(palimpsest_outbox_pending_rows)", "legendFormat": "pending" } ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Outbox oldest unprocessed age (seconds)",
      "description": "palimpsest_outbox_oldest_age_seconds vs the 60s SLO.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 60 } ] }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "max(palimpsest_outbox_oldest_age_seconds)", "legendFormat": "oldest unprocessed age" } ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Claim store — size & rowcounts (postgres_exporter)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Database size",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "pg_database_size_bytes{datname=\"palimpsest\"}", "legendFormat": "palimpsest" } ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Live row estimates by table",
      "description": "pg_stat_user_tables_n_live_tup — claim, claim_event, source_record, entity, entity_summary, outbox, ...",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "topk(15, pg_stat_user_tables_n_live_tup{datname=\"palimpsest\"})", "legendFormat": "{{relname}}" }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Data-quality anomaly counters (§4 Flow A / §19 FIX-ANOMALY)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Anomaly counters over time by class",
      "description": "palimpsest_anomaly_total{class=...}: odnb_zero_sentinel, valid_time_inverted_dropped_bounds, relationship_dangling_endpoint_skipped, bad_year_value, repeated_odnb_id.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (class) (palimpsest_anomaly_total)", "legendFormat": "{{class}}" }
      ]
    }
  ]
}
