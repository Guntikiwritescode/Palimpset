{
  "name": "@palimpsest/sdk",
  "version": "0.1.0",
  "description": "Generated TypeScript client for the PALIMPSEST engine API. Never hand-edit src/schema.d.ts.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "openapi-typescript openapi.json -o src/schema.d.ts",
    "check": "bash generate.sh --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
